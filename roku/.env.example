# Copy to .env and fill in your Roku's values.
# Enable Developer Mode on your Roku: Home x3, Up, Right, Down, Left, Up

# Primary Roku device (used by: deploy, deploy:screensaver, telnet, launch.json Channel/Screensaver)
ROKU_HOST=192.168.1.x
ROKU_PASSWORD=your-developer-password

# Second Roku device, e.g. living room (used by: deploy:livingroom, launch.json Livingroom configs)
ROKU_LIVINGROOM_HOST=192.168.1.y
ROKU_LIVINGROOM_PASSWORD=your-developer-password
