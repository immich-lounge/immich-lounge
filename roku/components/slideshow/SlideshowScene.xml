<?xml version="1.0" encoding="utf-8" ?>
<component name="SlideshowScene" extends="Scene">
  <interface>
    <field id="profile"        type="assocarray" value="{}" />
    <field id="playlist"       type="array"      value="[]" />
    <field id="companionUrl"   type="string"     value="" />
    <field id="profileId"      type="string"     value="" />
    <field id="isScreensaver"  type="boolean"    value="false" />
    <field id="useLocalDateFormatting" type="boolean" value="false" />
    <field id="playlistOffset" type="integer"    value="0" />
    <field id="nextPlaylistOffset" type="integer" value="0" />
    <field id="totalPlaylistCount" type="integer" value="0" />
    <field id="startPlaylistIndex" type="integer" value="0" />
    <field id="openSettingsOnStart" type="boolean" value="false" />
    <field id="paused"         type="boolean"    value="false" onChange="OnPausedChanged" />
    <field id="triggerRefresh" type="boolean"    value="false" onChange="OnTriggerRefresh" />
    <!-- Output signals -->
    <field id="requestChangeProfile" type="boolean" value="false" />
    <field id="requestChangeCompanion" type="boolean" value="false" />
    <field id="requestExit"          type="boolean" value="false" />
  </interface>
  <children>
    <PlaybackCanvas id="playbackCanvas" />

    <!-- Overlay component -->
    <OverlayComponent id="overlay" />

    <WeatherAndClockOverlay id="persistentLayer" translation="[1524, 54]" opacity="0.82" />

    <PlaybackStatusOverlay id="statusOverlay" />

    <!-- Screensaver prevention: disableScreenSaver keeps Roku awake without audio.
         1×1 invisible Video node; no content loaded — only the disableScreenSaver field is used. -->
    <Video id="screensaverControl" translation="[0,0]" width="1" height="1" visible="false" />
  </children>
  <script type="text/brightscript" uri="pkg:/source/Utils.brs" />
  <script type="text/brightscript" uri="pkg:/source/MediaUrls.brs" />
  <script type="text/brightscript" uri="pkg:/source/DateTimeFormatting.brs" />
  <script type="text/brightscript" uri="pkg:/source/PlaybackConstants.brs" />
  <script type="text/brightscript" uri="pkg:/components/playback/PlaybackRing.brs" />
  <script type="text/brightscript" uri="pkg:/components/playback/PlaybackCycle.brs" />
  <script type="text/brightscript" uri="pkg:/components/playback/PlaybackLoading.brs" />
  <script type="text/brightscript" uri="pkg:/components/playback/PlaybackTransitions.brs" />
  <script type="text/brightscript" uri="pkg:/components/playback/PlaybackBatching.brs" />
  <script type="text/brightscript" uri="pkg:/components/playback/PlaybackAdvance.brs" />
  <script type="text/brightscript" uri="pkg:/components/playback/PlaybackRecovery.brs" />
  <script type="text/brightscript" uri="pkg:/components/playback/PlaybackState.brs" />
  <script type="text/brightscript" uri="pkg:/components/playback/PlaybackRefresh.brs" />
  <script type="text/brightscript" uri="pkg:/components/playback/PlaybackProfile.brs" />
  <script type="text/brightscript" uri="pkg:/components/playback/PlaybackSetup.brs" />
  <script type="text/brightscript" uri="pkg:/components/playback/PlaybackEffects.brs" />
  <script type="text/brightscript" uri="pkg:/source/PlaylistRegistry.brs" />
  <script type="text/brightscript" uri="pkg:/source/WeatherAndClock.brs" />
  <script type="text/brightscript" uri="pkg:/source/WeatherAndClockController.brs" />
  <script type="text/brightscript" uri="pkg:/source/Registry.brs" />
  <script type="text/brightscript" uri="pkg:/source/HttpClient.brs" />
  <script type="text/brightscript" uri="pkg:/components/slideshow/SlideshowDialogs.brs" />
  <script type="text/brightscript" uri="pkg:/components/slideshow/SlideshowScene.brs" />
</component>
